# backend/.env.example — copia como .env y llena los valores

# Football-Data.org (gratis en https://www.football-data.org/)
FOOTBALL_DATA_TOKEN=tu_token_aqui

# API-Football via RapidAPI (opcional, para xG enriquecido)
RAPIDAPI_KEY=tu_key_aqui

# AWS (solo para deploy Lambda)
AWS_REGION=us-east-1
S3_BUCKET=tortia-mundialista-artifacts

# Redis (opcional — feature store)
REDIS_URL=redis://localhost:6379/0

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
MODEL_DIR=artifacts
ENSEMBLE_ALPHA=0.55
